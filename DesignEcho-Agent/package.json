{
    "name": "designecho-agent",
    "version": "1.0.0",
    "description": "DesignEcho Agent - AI-powered design assistant",
    "main": "dist/main/main/index.js",
    "scripts": {
        "dev": "npm run build && electron .",
        "dev:watch": "concurrently -k \"vite build --watch\" \"tsc -p tsconfig.main.json --watch\"",
        "build": "npm run build:main && npm run build:renderer",
        "build:main": "tsc -p tsconfig.main.json",
        "build:renderer": "vite build",
        "start": "npm run build && electron .",
        "test:morphing": "node scripts/run-morphing-tests.js",
        "audit:handlers": "node scripts/check-handler-aliases.js",
        "test": "npm run audit:handlers && npm run test:morphing",
        "pack": "electron-builder --dir",
        "dist": "electron-builder"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.30.0",
        "@google/generative-ai": "^0.21.0",
        "@lancedb/lancedb": "^0.23.0",
        "@types/form-data": "^2.2.1",
        "@types/uuid": "^10.0.0",
        "@xenova/transformers": "^2.17.2",
        "ag-psd": "^29.1.0",
        "axios": "^1.13.2",
        "form-data": "^4.0.5",
        "onnxruntime-node": "^1.23.2",
        "openai": "^4.70.0",
        "sharp": "^0.34.5",
        "uuid": "^13.0.0",
        "ws": "^8.18.0",
        "zustand": "^4.5.0"
    },
    "devDependencies": {
        "@types/node": "^20.19.30",
        "@types/react": "^18.2.0",
        "@types/react-dom": "^18.2.0",
        "@types/ws": "^8.5.0",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.16",
        "concurrently": "^8.2.0",
        "cross-env": "^10.1.0",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.0",
        "postcss": "^8.4.32",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "tailwindcss": "^3.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.3.3",
        "vite": "^5.0.0"
    },
    "build": {
        "appId": "com.designecho.agent",
        "productName": "DesignEcho",
        "directories": {
            "output": "release"
        },
        "files": [
            "dist/**/*",
            "node_modules/**/*",
            "public/**/*"
        ],
        "win": {
            "target": "nsis",
            "icon": "resources/icon.ico"
        },
        "mac": {
            "target": "dmg",
            "icon": "resources/icon.icns"
        }
    }
}
