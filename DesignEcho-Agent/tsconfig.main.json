{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "lib": ["ES2022", "DOM"],
        "outDir": "./dist/main",
        "rootDir": "./src",
        "strict": true,
        "noImplicitAny": false,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "sourceMap": true,
        "composite": true,
        "baseUrl": ".",
        "paths": {
            "@shared/*": ["src/shared/*"]
        },
        "types": ["node"]
    },
    "include": ["src/main/**/*", "src/shared/**/*"],
    "exclude": ["node_modules", "src/renderer/**/*"]
}
